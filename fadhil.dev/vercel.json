{
  "version": 2,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.fadhil.qzz.io" }],
      "destination": "https://fadhil.qzz.io/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/testing", "destination": "/testing/index.html" },
    { "source": "/testing/", "destination": "/testing/index.html" },
    { "source": "/Testing", "destination": "/testing/index.html" },
    { "source": "/Testing/", "destination": "/testing/index.html" },
    { "source": "/favicon.png", "destination": "/favicon.ico" }
  ],
  "headers": [
    {
      "source": "/testing",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" }]
    },
    {
      "source": "/testing/(.*)",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" }]
    },
    {
      "source": "/Testing",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" }]
    },
    {
      "source": "/Testing/(.*)",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" }]
    }
  ]
}
