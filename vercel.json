{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "website/home/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "website/portfolio/**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "website/portfolio/testing/**",
      "use": "@vercel/static"
    },
    {
      "src": "website/website/mindmapmaker/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "website/website/Books/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "shareideas/**",
      "use": "@vercel/static"
    },
    {
      "src": "library/**",
      "use": "@vercel/static"
    },
    {
      "src": "Assets/Public/Images/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/shareideas",
      "dest": "/api/shareideas.js"
    },
    {
      "src": "/api/shareideas/",
      "dest": "/api/shareideas.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.js"
    },
    {
      "src": "/$",
      "dest": "/website/portfolio/index.html"
    },
    {
      "src": "/games/dreambusiness",
      "dest": "/mindmapmaker/dreambusiness"
    },
    {
      "src": "/games/dreambusiness/",
      "dest": "/mindmapmaker/dreambusiness"
    },
    {
      "src": "/dreambusiness",
      "dest": "/mindmapmaker/dreambusiness"
    },
    {
      "src": "/dreambusiness/",
      "dest": "/mindmapmaker/dreambusiness"
    },
    {
      "src": "/home",
      "dest": "/website/home/index.html"
    },
    {
      "src": "/home/",
      "dest": "/website/home/index.html"
    },
    {
      "src": "/home/(.*)",
      "dest": "/website/home/$1"
    },
    {
      "src": "/portfolio",
      "dest": "/website/portfolio/index.html"
    },
    {
      "src": "/portfolio/",
      "dest": "/website/portfolio/index.html"
    },
    {
      "src": "/portfolio/testing/(.*)",
      "dest": "/website/portfolio/testing/$1"
    },
    {
      "src": "/mindmapmaker",
      "dest": "/website/website/mindmapmaker/index.html"
    },
    {
      "src": "/mindmapmaker/",
      "dest": "/website/website/mindmapmaker/index.html"
    },
    {
      "src": "/mindmapmaker/editor/([0-9]+)",
      "dest": "/website/website/mindmapmaker/editor/index.html"
    },
    {
      "src": "/editor",
      "status": 308,
      "headers": {
        "Location": "/mindmapmaker/editor/1"
      }
    },
    {
      "src": "/editor/([0-9]+)",
      "dest": "/website/website/mindmapmaker/editor/index.html"
    },
    {
      "src": "/Books",
      "dest": "/website/website/Books/index.html"
    },
    {
      "src": "/Books/",
      "dest": "/website/website/Books/index.html"
    },
    {
      "src": "/Books/Editor",
      "dest": "/website/website/Books/Editor/index.html"
    },
    {
      "src": "/Books/Editor/",
      "dest": "/website/website/Books/Editor/index.html"
    },
    {
      "src": "/Books/(.*)",
      "dest": "/website/website/Books/$1"
    },
    {
      "src": "/shareideas",
      "dest": "/shareideas/index.html"
    },
    {
      "src": "/shareideas/",
      "dest": "/shareideas/index.html"
    },
    {
      "src": "/shareideas/page/([0-9]+)",
      "dest": "/shareideas/workspace.html"
    },
    {
      "src": "/shareideas/(.*)",
      "dest": "/shareideas/$1"
    },
    {
      "src": "/library/(.*)",
      "dest": "/library/$1"
    },
    {
      "src": "/mindmapmaker/(.*)",
      "dest": "/website/website/mindmapmaker/$1"
    },
    {
      "src": "/Assets/Public/Images/(.*)",
      "dest": "/Assets/Public/Images/$1"
    },
    {
      "src": "/portfolio.webp",
      "dest": "/Assets/Public/Images/Portfolio.webp"
    }
  ]
}
