{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "database/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/Portfolio",
      "status": 308,
      "headers": {
        "Location": "/portfolio"
      }
    },
    {
      "src": "/((?!database/).*)",
      "dest": "/database/$1"
    }
  ]
}
