{
  "version": 2,
  "builds": [
    {
      "src": "mindmapmaker/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "website/portfolio/**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "website/portfolio/testing/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/portfolio",
      "dest": "/website/portfolio/index.html"
    },
    {
      "src": "/portfolio/",
      "dest": "/website/portfolio/index.html"
    },
    {
      "src": "/portfolio/testing/(.*)",
      "dest": "/website/portfolio/testing/$1"
    },
    {
      "src": "/$",
      "status": 308,
      "headers": {
        "Location": "/mindmapmaker"
      }
    },
    {
      "src": "/(workspace|archive-lab|game-ideas|game|BotMaker|EngineTest|TestEngine|fadhilweblib|FadhilAI-Focused-To-Generate-visual-War-Strategy)$",
      "status": 308,
      "headers": {
        "Location": "/mindmapmaker/$1"
      }
    },
    {
      "src": "/(editor|view)/(.*)",
      "status": 308,
      "headers": {
        "Location": "/mindmapmaker/$1/$2"
      }
    },
    {
      "src": "/mindmapmaker/public/(.*)",
      "dest": "/$1"
    },
    {
      "src": "/mindmapmaker",
      "dest": "/"
    },
    {
      "src": "/mindmapmaker/(.*)",
      "dest": "/$1"
    }
  ]
}
